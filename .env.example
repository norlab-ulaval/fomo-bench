###### IMPORTANT ######
# All paths must be absolute

OUTPUT_PATH_HOST=/home/matej/Desktop/evaluation_red_full

# path on the host that's preserved between different runs
# the evaluated algorithms can use the path to save data between runs
PROCESSING_PATH_BASE="/home/matej/Desktop/evaluation_red_full_data"

DEV_DOCKER=1 # set to 1 to tuse the local docker image. Otherwise pull from norlab's github

OVERWRITE=0 # overwrite existing output in $OUTPUT_PATH_HOST and $PROCESSING_PATH_BASE

ROSBAG_PLAY_RATE=1.0
ROSBAG_READ_AHEAD_QUEUE_SIZE=10000

OUTPUT_FILE_NAME="" # If empty, the default name will be used.

# SLAM methods to evaluate. Choose at least one from the list
SLAM_IMAGES=("norlab/vtr:latest" "norlab/icpmapper:latest" "norlab/orbslam3:latest", "kaist/navtechradarslam" "norlab/droidslam:latest")

FOMO_UID=1002 # replace this with the output of id -u. Default is 1000
FOMO_GID=1004 # replace this with the output of id -g. Default is 1000

COPY_EXISTING_MCAP=1 # copy existing mcap from the remote if it exists there already
COPY_MCAP_TO_REMOTE=0 # copy generated mcap to remote

SLAM_CPU_LIMIT=3
SLAM_RAM_LIMIT="5G"

ROSBAG_PLAY_CPU_LIMIT=2
ROSBAG_PLAY_RAM_LIMIT="25G"

# If empty, only the basic topics will be used.
# Basic topics: /tf_static /vectornav/data_raw /xsens/data_raw /warthog/platform/odom
TOPICS_FILE="/home/matej/fomo-bench/topics/topics-stereovslam.txt" # Must be a full path to the topics file

CONFIG_OVERWRITE_PATH="/home/mbo/legs_ws/fomo-bench/ros_launchers/config/_droid_slam.yaml" # this one is still WIP

IMU_TYPE="vectornav" # vectornav or xsens
RUN_SLAM=1 # if true, runs the SLAM evaluation. Otherwise just recomputes the evaluation metrics

# Evaluates $SLAM_IMAGE with the cross-seasonal pipeline
# fill these variables before running the run_pipeline_seasons.sh script
BASE_PATH_HOST=/media/kamyar/local_nas/FOMO/vslam_data # local path where the data are stored. Must be in the fomo deployment/recording format
BASE_PATH_REMOTE=/home/mabox/bigfoot-FoMo # remote path where the data are stored. Must be in the fomo deployment/recording format

TARGET_DEPLOYMENTS=("2024-11-21" "2024-11-28" "2025-01-10"  "2025-01-29" "2025-03-10" "2025-04-15" "2025-05-28" "2025-06-26" "2025-08-20" "2025-09-24" "2025-10-14" "2025-11-03")
TARGET_TRAJECTORY_NAME="red"
